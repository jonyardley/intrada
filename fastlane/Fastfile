default_platform(:ios)

# See specs/ios-testflight-cicd.md. The project is generated by xcodegen, so
# `xcodegen generate` (run by the CI workflow / `just testflight`) MUST precede
# this lane — there is no checked-in ios/Intrada.xcodeproj.
APP_IDENTIFIER = "com.intrada.native".freeze
TEAM_ID = "9S5FG4LQAF".freeze
PROFILE_NAME = "match AppStore #{APP_IDENTIFIER}".freeze

platform :ios do
  desc "Build a signed Release .ipa and upload it to TestFlight (internal testing)."
  lane :beta do
    # On CI, create an unlocked temporary keychain for match to import the cert
    # into — otherwise codesign blocks on a keychain UI prompt that never comes
    # and the job hangs to the timeout. No-op locally.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    # Pull the Apple Distribution cert + App Store profile from the certs repo
    # into a temp keychain. readonly: CI never creates/mutates signing assets —
    # bootstrap is a one-time local `fastlane match appstore` (see spec).
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    # Flip the freshly-generated project to manual signing with the match
    # profile. Done here (not in project.yml) so the daily simulator loop keeps
    # Automatic signing — see spec decision #3.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Intrada.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE_NAME,
      bundle_identifier: APP_IDENTIFIER,
      targets: ["Intrada"]
    )

    # Build number must be unique per (MARKETING_VERSION, build) for TestFlight.
    # github.run_number is monotonic; default 1 for local runs. Injected as a
    # build setting because CFBundleVersion is generated from it under
    # GENERATE_INFOPLIST_FILE=YES (PlistBuddy on the partial plist won't work).
    build_number = ENV.fetch("BUILD_NUMBER", "1")

    # Tag-derived (v0.3.0 → 0.3.0) so each tagged release is a new TestFlight
    # version. Unset (local runs, branch dispatch): project.yml's value.
    marketing_version = ENV.fetch("MARKETING_VERSION", "").delete_prefix("v")
    unless marketing_version.empty? || marketing_version.match?(/\A\d+\.\d+\.\d+\z/)
      UI.user_error!("MARKETING_VERSION #{marketing_version.inspect} is not X.Y.Z")
    end

    xcargs = [
      "CURRENT_PROJECT_VERSION=#{build_number}",
      ("MARKETING_VERSION=#{marketing_version}" unless marketing_version.empty?),
      "-clonedSourcePackagesDirPath build/spm"
    ].compact.join(" ")

    build_app(
      project: "ios/Intrada.xcodeproj",
      scheme: "Intrada",
      configuration: "Release",
      output_directory: "build",
      output_name: "Intrada.ipa",
      # "app-store" is universally accepted; Xcode 26 prints a harmless
      # "use app-store-connect" deprecation warning.
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { APP_IDENTIFIER => PROFILE_NAME }
      },
      xcargs: xcargs
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
