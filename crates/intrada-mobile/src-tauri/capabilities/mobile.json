{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Intrada iOS capabilities",
  "platforms": ["iOS"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "haptics:allow-selection-feedback",
    "haptics:allow-impact-feedback",
    "haptics:allow-notification-feedback",
    "haptics:allow-vibrate",
    "deep-link:default"
  ]
}
