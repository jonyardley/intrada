# Tauri-generated iOS Xcode project (regenerated by cargo tauri ios init)
crates/intrada-mobile/src-tauri/gen/
# Tauri-vendored Swift umbrella package, copied into each iOS plugin by
# `cargo tauri ios init` from tauri-cli's bundled assets — should be
# regenerated, not committed.
crates/intrada-mobile/plugins/*/.tauri/
# Swift package resolution lockfile — regenerated on each iOS build.
crates/intrada-mobile/plugins/*/ios/Package.resolved
*.xcuserdata/
# Xcode/SwiftPM per-user data (schemes, breakpoints) — not just *.xcuserdata dirs
.swiftpm/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
crates/intrada-web/test-results/
design/images/generated-*.png
# Ad-hoc macOS screenshots dropped into design/ — scratch, not design sources
design/Screenshot*.png
# Superpowers plugin scratch (brainstorm servers, etc.)
.superpowers/
# Native iOS — generated Swift packages (UniFFI bindings + facet typegen).
# A build precondition, regenerated by `just native-gen` — never committed.
ios/generated/
crates/intrada-ffi/generated/
crates/intrada-ffi/IntradaCoreFFI/
# xcodegen-generated project + xcodebuild output (regenerated from project.yml)
ios/*.xcodeproj/
ios/build/
# fastlane TestFlight lane output (build dir holds the .ipa/.xcarchive) + scratch.
# Gemfile.lock is intentionally NOT ignored — commit it for reproducible CI.
/build/
*.xcarchive
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
# graphify knowledge-graph output: machine-local, never committed (a re-recorded
# multi-MB graph.json compounds in history like snapshot PNGs). The canonical
# graph lives in the main checkout; scope is controlled by the committed
# .graphifyignore. See CLAUDE.md "Knowledge graph (graphify)".
graphify-out/
