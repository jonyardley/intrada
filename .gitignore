# Tauri-vendored Swift umbrella package, copied into each iOS plugin by
# `cargo tauri ios init` from tauri-cli's bundled assets — should be
# regenerated, not committed.
crates/intrada-mobile/plugins/*/.tauri/
# Swift package resolution lockfile — regenerated on each iOS build.
crates/intrada-mobile/plugins/*/ios/Package.resolved
