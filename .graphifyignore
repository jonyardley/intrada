# Scope for the graphify knowledge graph (gitignore syntax; graphify also
# honours .gitignore). Keeps vendored/minified/generated/archived files out of
# the graph; without these the god nodes are minified Clerk/Sentry symbols.

# Vendored / minified JS
support.js

# Design-system exports (large generated HTML) + image assets
*.dc.html
design/intrada-design-system.html
design/assets/
ios/AppIcon-exports/

# Retired / archived docs: reference only, they drown the live doc graph
specs/_archive/
.specify/
docs/superpowers/

# Images (snapshot test references, icons): no semantic value in the graph,
# and each image costs its own vision-extraction agent
*.png
*.svg
*.jpg
*.jpeg
*.ico
*.icns

# Font licence text: noise concepts, no repo knowledge
ios/Intrada/Resources/Fonts/

# Stale generated typegen output (old layout, superseded by ios/generated)
crates/shared_types/generated/
