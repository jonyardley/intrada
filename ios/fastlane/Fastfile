default_platform(:ios)

# ─────────────────────────────────────────────
# Configuration
# ─────────────────────────────────────────────

XCODE_PROJECT = "Intrada.xcodeproj"
SCHEME = "Intrada"
BUNDLE_ID = "com.intrada.app"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  # ─────────────────────────────────────────────
  # Build for simulator (CI verification)
  # ─────────────────────────────────────────────
  desc "Build for iOS simulator (no code signing)"
  lane :build do
    build_app(
      project: XCODE_PROJECT,
      scheme: SCHEME,
      destination: "platform=iOS Simulator,name=iPhone 16 Pro,OS=18.5",
      configuration: "Release",
      skip_codesigning: true,
      skip_archive: true,
      build_path: "./build",
      derived_data_path: "./DerivedData"
    )
  end

  # ─────────────────────────────────────────────
  # Run unit tests
  # ─────────────────────────────────────────────
  desc "Run unit tests"
  lane :test do
    run_tests(
      project: XCODE_PROJECT,
      scheme: SCHEME,
      device: "iPhone 16 Pro",
      clean: true
    )
  end

  # ─────────────────────────────────────────────
  # Deploy to TestFlight
  # ─────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    # Fetch signing certificates and profiles
    match(type: "appstore", readonly: is_ci)

    # Auto-increment build number from TestFlight
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: XCODE_PROJECT
    )

    # Build the app
    build_app(
      project: XCODE_PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Intrada.ipa",
      derived_data_path: "./DerivedData",
      xcargs: "-allowProvisioningUpdates"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("Successfully uploaded build #{lane_context[SharedValues::BUILD_NUMBER]} to TestFlight!")
  end

  # ─────────────────────────────────────────────
  # Release to App Store
  # ─────────────────────────────────────────────
  desc "Build and submit to App Store review"
  lane :release do
    match(type: "appstore", readonly: is_ci)

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: XCODE_PROJECT
    )

    build_app(
      project: XCODE_PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Intrada.ipa",
      derived_data_path: "./DerivedData"
    )

    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true
    )
  end
end
